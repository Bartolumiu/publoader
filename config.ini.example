[Credentials]
MANGADEX_USERNAME=
MANGADEX_PASSWORD=
CLIENT_ID=
CLIENT_SECRET=
MONGODB_URI=
MONGODB_DB_NAME=
DISCORD_BOT_TOKEN=

[Options]
MANGADEX_RATELIMIT_TIME=2
MAX_REQUESTS=5
UPLOAD_RETRY=3
BOT_RUN_TIME_DAILY=15:00
BOT_RUN_TIME_CHECKS=01:00
MAX_LOG_DAYS=30

[Paths]
MANGADEX_API_URL=https://api.mangadex.org
MANGADEX_AUTH_URL=https://auth.mangadex.org/realms/mangadex/protocol/openid-connect
RESOURCES_PATH=resources
MDAUTH_PATH=resources/mdauth.json
COMMITS_PATH=.commits
# One or more discord webhook URLs; comma- or newline-separated for multiple.
WEBHOOK_URL=
MANGA_DATA_PATH=manga_data.json
DISCORD_COMMAND_PREFIX=!
DISCORD_GUILD_ID=
# Comma- or space-separated channel / thread IDs the bot accepts commands from.
# Leave blank to allow any channel the bot can see.
DISCORD_ALLOWED_CHANNELS=
# Users / roles permitted to invoke /add (and !add). Comma- or space-separated
# discord IDs. Leave both blank to allow anyone in the allowed channel(s).
DISCORD_ADMIN_USERS=
DISCORD_ADMIN_ROLES=

[Network]
# Outgoing-IP rotation to spread MangaDex requests across multiple source IPs
# and dodge per-IP rate-limit bans. Everything here is optional — leave blank
# to send from the single default outbound IP (the previous behaviour).
#
# Option 1 — proxy pool. Comma/newline-separated proxy URLs; a random one is
# picked per request, process-wide — this covers the in-process extension
# scrapers too (any extension using requests/cloudscraper), not just MangaDex
# uploads. http(s):// works out of the box; socks5:// needs `requests[socks]`
# (add `PySocks` to requirements). Takes precedence over the source-IP options
# below when set.
#   PROXIES=http://user:pass@1.2.3.4:8080, socks5://5.6.7.8:1080
PROXIES=
#
# Option 2 — bind each outgoing connection to a random local source IP. The
# host must actually own/route these addresses and allow binding to them.
# A routed IPv6 subnet (CIDR): SOURCE_IP_POOL_SIZE random addresses are drawn
# from it and rotated. Requires host setup — see docker/README "Outgoing IP
# rotation".
SOURCE_IPV6_SUBNET=
# Explicit source IPs the container already holds (comma/space separated).
SOURCE_IPS=
# How many addresses to generate from SOURCE_IPV6_SUBNET.
SOURCE_IP_POOL_SIZE=64
#
# Extension header spoofing. The in-process extension scrapers present as a real
# browser (a fresh, self-consistent User-Agent + client-hint header set per
# session) so third-party sites don't reject the default python-requests/aiohttp
# User-Agent. On by default; set to false to send each extension's native
# User-Agent instead. The MangaDex client is unaffected — it always identifies
# honestly as publoader/<version>.
SPOOF_EXTENSION_HEADERS=true
#
# Hosts that must NEVER be proxied (comma/space separated). The MongoDB host
# from MONGODB_URI and localhost are excluded automatically, so DB traffic
# always goes direct; add anything else here (e.g. a TLS cert's OCSP responder).
# The standard NO_PROXY/no_proxy env vars are honoured too.
#   NO_PROXY=ocsp.example-ca.com, internal.svc
NO_PROXY=

[Repo]
REPO_OWNER=publoader
BASE_REPO_PATH=publoader
EXTENSIONS_REPO_PATH=publoader-extensions
EXTENSIONS_PRIVATE_REPO_PATH=
GITHUB_ACCESS_TOKEN=

[GithubWebhook]
# Listen for GitHub push webhooks and download updates the instant code is
# pushed, instead of waiting for the daily restart (which stays as a fallback).
# Add a webhook on each tracked repo: Payload URL = the PATH below, content
# type application/json, secret = SECRET below, events = "push".
# Leave ENABLED=false to keep the polling-only behaviour.
ENABLED=false
# Address/port the listener binds inside the container. docker-compose `expose`s
# 8080 on the internal network (not on the host) and routes GitHub deliveries in
# through the cloudflared tunnel — see README "Push-based updates" for setup.
HOST=0.0.0.0
PORT=8080
PATH=/webhook
# Shared secret; must match the secret set on the GitHub webhook. Required —
# the listener refuses to start without one.
SECRET=

[Dashboard]
# Web control panel that views all bot state and drives every control command,
# gated behind Discord OAuth login. Served by the publoader-dash container and
# routed in through the Cloudflare tunnel — see the README "Dashboard" section.
# Leave ENABLED=false to keep the dashboard off (its container idles).
ENABLED=false
# Address/port the dashboard binds inside the container (not published on the
# host; reached only via the tunnel).
HOST=0.0.0.0
PORT=8090
# Discord OAuth2 application (https://discord.com/developers/applications):
#   OAuth2 page -> copy CLIENT ID and a CLIENT SECRET, and add REDIRECT_URI
#   below to the "Redirects" allowlist. Only the `identify` scope is requested.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must exactly match a redirect registered on the Discord app and be reachable
# publicly (the tunnel hostname + /auth/callback).
REDIRECT_URI=https://publoader.ardax.dev/auth/callback
# Secret used to sign session cookies. REQUIRED for production — without it a
# random one is generated per start and every session drops on restart.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# Discord user IDs allowed to log in (comma/space separated). Leave blank to
# reuse [Paths]DISCORD_ADMIN_USERS.
ALLOWED_USERS=
# Minutes a login stays valid before re-auth.
SESSION_TTL_MINUTES=720
