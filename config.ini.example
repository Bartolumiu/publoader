[Credentials]
MANGADEX_USERNAME=
MANGADEX_PASSWORD=
CLIENT_ID=
CLIENT_SECRET=
MONGODB_URI=
MONGODB_DB_NAME=
DISCORD_BOT_TOKEN=

[Options]
MANGADEX_RATELIMIT_TIME=2
MAX_REQUESTS=5
UPLOAD_RETRY=3
BOT_RUN_TIME_DAILY=15:00
BOT_RUN_TIME_CHECKS=01:00
MAX_LOG_DAYS=30

[Paths]
MANGADEX_API_URL=https://api.mangadex.org
MANGADEX_AUTH_URL=https://auth.mangadex.org/realms/mangadex/protocol/openid-connect
RESOURCES_PATH=resources
MDAUTH_PATH=resources/mdauth.json
COMMITS_PATH=.commits
# One or more discord webhook URLs; comma- or newline-separated for multiple.
WEBHOOK_URL=
MANGA_DATA_PATH=manga_data.json
DISCORD_COMMAND_PREFIX=!
DISCORD_GUILD_ID=
# Comma- or space-separated channel / thread IDs the bot accepts commands from.
# Leave blank to allow any channel the bot can see.
DISCORD_ALLOWED_CHANNELS=
# Users / roles permitted to invoke /add (and !add). Comma- or space-separated
# discord IDs. Leave both blank to allow anyone in the allowed channel(s).
DISCORD_ADMIN_USERS=
DISCORD_ADMIN_ROLES=

[Repo]
REPO_OWNER=publoader
BASE_REPO_PATH=publoader
EXTENSIONS_REPO_PATH=publoader-extensions
EXTENSIONS_PRIVATE_REPO_PATH=
GITHUB_ACCESS_TOKEN=

[GithubWebhook]
# Listen for GitHub push webhooks and download updates the instant code is
# pushed, instead of waiting for the daily restart (which stays as a fallback).
# Add a webhook on each tracked repo: Payload URL = the PATH below, content
# type application/json, secret = SECRET below, events = "push".
# Leave ENABLED=false to keep the polling-only behaviour.
ENABLED=false
# Address/port the listener binds inside the container. docker-compose `expose`s
# 8080 on the internal network (not on the host) and routes GitHub deliveries in
# through the cloudflared tunnel — see README "Push-based updates" for setup.
HOST=0.0.0.0
PORT=8080
PATH=/webhook
# Shared secret; must match the secret set on the GitHub webhook. Required —
# the listener refuses to start without one.
SECRET=
